# ============================================================
# NutriGuard AI — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to source control!
# ============================================================

# ---- Google AI (REQUIRED) ----
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ---- Google Cloud Project ----
# Your Google Cloud project ID
GOOGLE_CLOUD_PROJECT=nutriguard-ai-hackathon

# ---- Google Maps (Optional — enables real hospital/pharmacy lookup) ----
# Get from: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# ---- Fivetran (Partner Track — Required for Fivetran prize) ----
# Get from: https://fivetran.com/account/settings -> API Keys
# Docs: https://fivetran.com/docs/rest-api/getting-started#authentication
FIVETRAN_API_KEY=your_fivetran_api_key_here
FIVETRAN_API_SECRET=your_fivetran_api_secret_here

# ---- Google BigQuery (Used by Fivetran as destination) ----
# Service account JSON path for local dev
GOOGLE_APPLICATION_CREDENTIALS=config/service_account.json
BIGQUERY_DATASET=nutriguard_ai

# ---- Secret Manager (Production Cloud Run) ----
# When deployed to Cloud Run, secrets are pulled from Secret Manager.
# Set USE_SECRET_MANAGER=true to enable.
USE_SECRET_MANAGER=false

# ---- Server Config ----
HOST=0.0.0.0
PORT=8080
WORKERS=1
LOG_LEVEL=info

# ---- App Config ----
ENVIRONMENT=development
# ENVIRONMENT=production
